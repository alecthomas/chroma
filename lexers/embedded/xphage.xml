<lexer>
  <config>
    <name>X-Phage</name>
    <alias>xphage</alias>
    <filename>*.xp0</filename>
    <filename>*.xh</filename>
    <filename>*.xui</filename>
    <mime-type>text/xphage</mime-type>
  </config>
  <rules>
    <state name="root">
      <!-- Whitespace -->
      <rule pattern="\s+" token="Text"/>

      <!-- Single-line comments -->
      <rule pattern="//.*$" token="Comment.Single"/>

      <!-- Multi-line comments -->
      <rule pattern="/\*" token="Comment.Multiline" push="comment"/>

      <!-- Strings -->
      <rule pattern="&quot;(?:\\.|[^&quot;\\])*&quot;" token="String"/>

      <!-- Keywords (including control, modules, etc.) -->
      <rule pattern="\b(pulse|fusion|matrix|global|quantum|bypass|synapse|chronos|ether|void|scan|vortex|~link|math)\b" token="Keyword"/>

      <!-- Type keywords -->
      <rule pattern="\b(atom|shadow)\b" token="Keyword.Type"/>

      <!-- Built-in function -->
      <rule pattern="\b(beam)\b" token="Name.Function"/>

      <!-- UI component classes -->
      <rule pattern="\b(Signal|Vision|Orbit|Trigger|Input|Z_Plane)\b" token="Name.Class"/>

      <!-- Attributes -->
      <rule pattern="@[a-zA-Z_]+" token="Name.Attribute"/>

      <!-- Numbers (decimal and hex) -->
      <rule pattern="\b[0-9]+(\.[0-9]+)?\b|\b0x[0-9a-fA-F]+\b" token="Number"/>

      <!-- Operators -->
      <rule pattern="->" token="Operator"/>
      <rule pattern="[+\-*/=~]" token="Operator"/>

      <!-- Punctuation -->
      <rule pattern="[{}()\[\];,]" token="Punctuation"/>

      <!-- Identifiers -->
      <rule pattern="\b[A-Za-z_][A-Za-z0-9_]*\b" token="Name"/>
    </state>

    <state name="comment">
      <rule pattern="[^*/]+" token="Comment.Multiline"/>
      <rule pattern="\*/" token="Comment.Multiline" pop="true"/>
      <rule pattern="[*/]" token="Comment.Multiline"/>
    </state>
  </rules>
</lexer>